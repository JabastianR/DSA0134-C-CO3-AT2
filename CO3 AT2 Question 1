#include <iostream>
#include <cstring>
using namespace std;

class Student {
    char *name;
    int marks;

public:
    // Parameterized Constructor
    Student(const char *n, int m) {
        name = new char[strlen(n) + 1];
        strcpy(name, n);
        marks = m;
    }

    // Copy Constructor (Deep Copy)
    Student(const Student &s) {
        name = new char[strlen(s.name) + 1];
        strcpy(name, s.name);
        marks = s.marks;
    }

    void setName(const char *n) {
        delete[] name;
        name = new char[strlen(n) + 1];
        strcpy(name, n);
    }

    void display() {
        cout << "Name: " << name
             << ", Marks: " << marks << endl;
    }

    ~Student() {
        delete[] name;
    }
};

int main() {
    Student s1("Rahul", 85);   // Original object
    Student s2 = s1;           // Copy constructor

    s2.setName("Amit");        // Modify copied object

    cout << "Original Object:\n";
    s1.display();

    cout << "Copied Object:\n";
    s2.display();

    return 0;
}
