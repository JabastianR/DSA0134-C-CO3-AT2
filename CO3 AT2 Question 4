#include <iostream>
using namespace std;

class Box {
    int volume;

public:
    Box(int v) {
        volume = v;
    }

    bool operator>(Box b) {
        return volume > b.volume;
    }

    void display() {
        cout << "Volume = " << volume << endl;
    }
};

int main() {
    Box b1(150), b2(200);

    if (b1 > b2)
        cout << "Box 1 has greater volume";
    else
        cout << "Box 2 has greater volume";

    return 0;
}
